---
export const prerender = true;
const links = [
  { href: '/#experience', id: 'Experience', label: 'Experience' },
  { href: '/#writing', id: 'Writing', label: 'Writing' },
  { href: '/#talks', id: 'Talks', label: 'Talks' },
  { href: '/#contact', id: 'Contact', label: 'Contact' },
] as const;
---

<nav class="sticky top-0 z-50 border-b border-border bg-paper px-8">
  <div class="flex items-center justify-between space-around p py-5">
    <a
      href="/"
      class="font-mono text-base font-medium text-ink tracking-tight hover:text-green transition-colors pr-4"
    >
      Khalvai/
    </a>
    <div class="flex gap-4">
      {
        links.map(({ href, id, label }) => (
          <a
            href={href}
            data-section={id}
            class="nav-link text-[13px] no-underline tracking-wide text-ink-muted hover:text-ink transition-colors"
          >
            {label}
          </a>
        ))
      }
    </div>
  </div>
</nav>

<script>
  const sectionIds = ['Experience', 'Writing', 'Talks', 'Contact'];

  const setActive = (id: string) => {
    document
      .querySelectorAll<HTMLAnchorElement>('[data-section]')
      .forEach((link) => {
        const active = link.dataset.section === id;
        link.classList.toggle('text-ink', active);
        link.classList.toggle('text-ink-muted', !active);
      });
  };

  const hash = window.location.hash.slice(1);
  if (sectionIds.includes(hash)) {
    setActive(hash);
  }

  const observer = new IntersectionObserver(
    (entries) => {
      const visible = entries
        .filter((e) => e.isIntersecting)
        .sort((a, b) => b.intersectionRatio - a.intersectionRatio);
      if (visible[0]) {
        setActive(visible[0].target.id);
      }
    },
    { rootMargin: '-20% 0px -60% 0px', threshold: [0, 0.25, 0.5] }
  );

  sectionIds.forEach((id) => {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  });
</script>
