<div>
  <p class="text-[11px] text-ink-faint tracking-widest mb-4 font-mono uppercase">
    // how I think about systems
  </p>

  <svg width="100%" viewBox="0 0 360 280" role="img" aria-labelledby="arch-title arch-desc">
    <title id="arch-title">Layered system architecture diagram</title>
    <desc id="arch-desc">
      Concentric rectangles showing infrastructure wrapping application wrapping domain, with ports
      connecting the domain to the outside world.
    </desc>

    <!-- Infrastructure (outermost) -->
    <rect
      x="10"
      y="10"
      width="340"
      height="260"
      rx="12"
      fill="none"
      stroke="#c8c8c2"
      stroke-width="0.8"
      stroke-dasharray="4 3"></rect>
    <text
      x="24"
      y="30"
      font-size="10"
      fill="#9b9b94"
      font-family="monospace"
      letter-spacing="0.06em"
    >
      INFRASTRUCTURE
    </text>
    <text x="24" y="44" font-size="9" fill="#b8b8b2" font-family="monospace">
      HTTP · gRPC · DB · Queue
    </text>

    <!-- Application layer -->
    <rect
      x="50"
      y="58"
      width="260"
      height="164"
      rx="10"
      fill="#f0f0ec"
      stroke="#c8c8c2"
      stroke-width="0.5"></rect>
    <text
      x="64"
      y="76"
      font-size="10"
      fill="#9b9b94"
      font-family="monospace"
      letter-spacing="0.06em"
    >
      APPLICATION
    </text>
    <text x="64" y="89" font-size="9" fill="#b8b8b2" font-family="monospace">
      use cases · orchestration
    </text>

    <!-- Domain (innermost) -->
    <rect
      x="100"
      y="108"
      width="160"
      height="64"
      rx="8"
      fill="#e8f0e4"
      stroke="#3d6b3a"
      stroke-width="0.8"></rect>
    <text
      x="180"
      y="132"
      text-anchor="middle"
      font-size="12"
      fill="#1a1a18"
      font-family="monospace"
      font-weight="500"
    >
      DOMAIN
    </text>
    <text
      x="180"
      y="148"
      text-anchor="middle"
      font-size="10"
      fill="#3d6b3a"
      font-family="monospace"
    >
      business logic · rules
    </text>
    <text x="180" y="162" text-anchor="middle" font-size="9" fill="#6b9b68" font-family="monospace">
      the core stays pure
    </text>

    <!-- Port arrow — left (adapters driving into domain) -->
    <line
      x1="50"
      y1="140"
      x2="100"
      y2="140"
      stroke="#9b9b94"
      stroke-width="0.8"
      marker-end="url(#arrow)"></line>
    <text x="38" y="137" text-anchor="middle" font-size="9" fill="#9b9b94" font-family="monospace"
      >port</text
    >

    <!-- Port arrow — right (domain driving out to adapters) -->
    <line
      x1="260"
      y1="140"
      x2="310"
      y2="140"
      stroke="#9b9b94"
      stroke-width="0.8"
      marker-end="url(#arrow)"></line>
    <text x="322" y="137" text-anchor="middle" font-size="9" fill="#9b9b94" font-family="monospace"
      >port</text
    >

    <defs>
      <marker
        id="arrow"
        viewBox="0 0 10 10"
        refX="8"
        refY="5"
        markerWidth="5"
        markerHeight="5"
        orient="auto-start-reverse"
      >
        <path
          d="M2 1L8 5L2 9"
          fill="none"
          stroke="#9b9b94"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </marker>
    </defs>
  </svg>
</div>
