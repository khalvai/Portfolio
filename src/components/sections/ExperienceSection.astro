---
export const prerender = true;
const experiences = [
  {
    role: 'Senior Software Engineer',
    company: 'Intelika.ai',
    link: 'https://intelika.ai',
    period: 'Nov 2025 – Jun 2026',
    duration: '8 months',
    about:
      'AI services company building LLM-powered conversational experiences for enterprise customers.',
    highlights: [
      'In close collaboration with marketing team, engaged users to become customers in Finance service, by designing a system that offers trial subscriptions.',
      'Implemented a notification service, using event-driven architecture, to notify customers to renew the past-due subscriptions.',
      'Collaborated with DevOps engineers to define deployment architecture and improve production delivery workflows.',
      'Reduced message fetching latency by %50, using multi-stage migration, designing presentation service using MongoDB, delegation of JWT verification to the service.',
    ],
    stack: [
      'NestJS',
      'TypeScript',
      'Modular Monolith',
      'DDD',
      'Team Leadership',
    ],
  },
  {
    role: 'Software Engineer',
    company: 'Intelika.ai',
    link: 'https://intelika.ai',
    period: 'Jan 2024 – Nov 2025',
    duration: '2 years',
    about:
      'AI services company building LLM-powered conversational experiences for enterprise customers.',
    highlights: [
      'Implemented Stripe subscription workflows and integrated them with internal billing logic for automated monthly star refresh.',
      'Supported a team of 4 engineers in adopting Domain-Driven Design (DDD) and Hexagonal Architecture through structured knowledge-sharing sessions.',
      'Built an internal NestJS seedwork implementing DDD tactical patterns (Entities, Value Objects, Aggregates, Repositories), enabling consistent domain modeling across microservices.',
      'Decoupled communication protocols, HTTP and gRPC, from business logic, making the logic more understandable.',
      'Implemented inbox/outbox pattern, ensuring eventual consistency and idempotency of events.',
      'Discovered business bonded contexts and integrated domain model concepts into existing N-Layered Architecture.',
    ],
    stack: ['NestJS', 'TypeScript', 'DDD', 'gRPC', 'Microservices'],
  },
  {
    role: 'Backend Engineer',
    company: 'Nobati',
    link: 'https://nobati.app',
    period: 'Jan 2023 – Dec 2023',
    duration: '1 year',
    about:
      'Appointment management platform offering tailored scheduling solutions for businesses, serving over 200,000 users.',
    highlights: [
      'Solved payment issues and subscription issuance problems for users, creating a convenient purchase flow.',
      ' Migrated JavaScript codebase into TypeScript, using DDD, improving separation of concerns.',
      'Planned parallel development of legacy repositories alongside integration with new services.',
      'Contributed to the success of a company serving over +200K users by prioritizing solving existing challenges.',
      'Solved concurrency issue of reserving a slot of time for a user, using two level locks in the business process.',
    ],
    stack: ['NestJS', 'TypeScript', 'Hexagonal Arch.', 'CQRS', 'DDD'],
  },
  {
    role: 'Backend Developer',
    company: 'Asrez Group',
    link: 'https://github.com/Asrez',
    period: 'Jun 2022 – Dec 2022',
    duration: '7 months',
    about:
      'Web technology consultancy delivering creative software infrastructure solutions to clients.',
    highlights: [
      'Developed APIs using REST and GraphQL to support diverse client applications.',
      'Implemented an N-layered architecture in NestJS, ensuring scalability, testability, and clear separation of concerns.',
    ],
    stack: ['NestJS', 'TypeScript', 'REST', 'GraphQL'],
  },
];
---

<div class="max-w-3xl mx-auto">
  <ul class="border-l border-border space-y-14">
    {
      experiences.map((exp) => (
        <li class="relative pl-8">
          <div class="absolute -left-[4.5px] top-[7px] w-2 h-2 rounded-full bg-green ring-2 ring-paper" />

          <p class="text-[11px] font-mono text-ink-faint mb-1 tracking-wide">
            {exp.period} &nbsp;·&nbsp; {exp.duration}
          </p>
          <h3 class="text-base font-medium text-ink leading-snug">
            {exp.role}
          </h3>
          <p class="text-[13px] text-green mb-3">
            <a href={exp.link} target="_blank" rel="noopener noreferrer">
              {exp.company}
            </a>
          </p>
          <p class="text-[13px] text-ink-muted mb-4 leading-relaxed italic">
            {exp.about}
          </p>

          <ul class="space-y-2 mb-5">
            {exp.highlights.map((point) => (
              <li class="flex gap-3 text-[13px] text-ink-muted leading-relaxed">
                <span class="text-green mt-px select-none flex-shrink-0">
                  —
                </span>
                <span>{point}</span>
              </li>
            ))}
          </ul>

          <div class="flex gap-2 flex-wrap">
            {exp.stack.map((tech) => (
              <span class="text-[11px] font-mono text-ink-faint bg-surface px-2.5 py-1 rounded">
                {tech}
              </span>
            ))}
          </div>
        </li>
      ))
    }
  </ul>
</div>
