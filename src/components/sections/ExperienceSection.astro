---
const experiences = [
  {
    role: 'Backend Engineer',
    company: 'Lexika.ai',
    link: 'https://lexika.ai',
    location: 'Dubai, UAE',
    period: 'Jan 2024 – Mar 2026',
    duration: '2 years 3 months',
    about:
      'AI services company building LLM-powered conversational experiences for enterprise customers.',
    highlights: [
      'Built an internal NestJS seedwork framework adopted across 3 development teams, standardising architecture and reducing onboarding effort.',
      'Decoupled HTTP and gRPC communication protocols from business logic, making domain code independently testable and readable.',
      'Supported code reviews, mentoring, and knowledge sharing for 4+ engineers, contributing to architecture decisions and team growth.',
      'Documented the adopted architecture and recorded video walkthroughs explaining the mindset behind Domain-Driven Design.',
      'Mentored and onboarded 2 interns, supporting their growth and successful integration into the development team.',
    ],
    stack: ['NestJS', 'TypeScript', 'DDD', 'gRPC', 'LLM Integration'],
  },
  {
    role: 'Backend Engineer',
    company: 'Nobati.app',
    link: 'https://nobati.app',
    location: 'Qazvin, Iran',
    period: 'Jan 2023 – Jan 2024',
    duration: '1 year 1 month',
    about: 'Appointment management platform offering tailored scheduling solutions for businesses.',
    highlights: [
      'Designed event-driven microservices with CQRS patterns, handling async workflows and decoupled service communication reliably.',
      'Built scalable REST APIs using Hexagonal Architecture, ensuring clean service boundaries and long-term maintainability.',
      'Implemented CQRS with separate read and write models to develop modular, scalable, and maintainable systems.',
    ],
    stack: ['NestJS', 'TypeScript', 'Hexagonal Arch.', 'CQRS', 'Microservices'],
  },
  {
    role: 'Backend Developer',
    company: 'Asrez Group',
    link: 'https://github.com/Asrez',
    location: 'Tehran, Iran',
    period: 'Feb 2022 – Jan 2023',
    duration: '1 year',
    about:
      'Web technology consultancy delivering creative software infrastructure solutions to clients.',
    highlights: [
      'Developed APIs using REST and GraphQL to support diverse client-facing applications.',
      'Implemented an N-layered architecture in NestJS, ensuring scalability, testability, and clear separation of concerns.',
    ],
    stack: ['NestJS', 'TypeScript', 'REST', 'GraphQL'],
  },
];
---

<div class="max-w-3xl mx-auto">
  <ul class="border-l border-border space-y-14">
    {
      experiences.map((exp) => (
        <li class="relative pl-8">
          <div class="absolute -left-[4.5px] top-[7px] w-2 h-2 rounded-full bg-green ring-2 ring-paper" />

          <p class="text-[11px] font-mono text-ink-faint mb-1 tracking-wide">
            {exp.period} &nbsp;·&nbsp; {exp.duration} &nbsp;·&nbsp; {exp.location}
          </p>
          <h3 class="text-base font-medium text-ink leading-snug">{exp.role}</h3>
          <p class="text-[13px] text-green mb-3"><a href={exp.link} target="_blank" rel="noopener noreferrer">{exp.company}</a></p>
          <p class="text-[13px] text-ink-muted mb-4 leading-relaxed italic">{exp.about}</p>

          <ul class="space-y-2 mb-5">
            {exp.highlights.map((point) => (
              <li class="flex gap-3 text-[13px] text-ink-muted leading-relaxed">
                <span class="text-green mt-px select-none flex-shrink-0">—</span>
                <span>{point}</span>
              </li>
            ))}
          </ul>

          <div class="flex gap-2 flex-wrap">
            {exp.stack.map((tech) => (
              <span class="text-[11px] font-mono text-ink-faint bg-surface px-2.5 py-1 rounded">
                {tech}
              </span>
            ))}
          </div>
        </li>
      ))
    }
  </ul>
</div>
