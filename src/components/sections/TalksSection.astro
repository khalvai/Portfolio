---
import { talks } from '@/content/talks/talks.astro';

const formatDate = (d: string) =>
  new Date(d).toLocaleDateString('en-GB', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
---

<div class="max-w-3xl mx-auto">
  <ul class="grid grid-cols-1 sm:grid-cols-2 gap-8">
    {
      talks.map((talk) => (
        <li class="group flex flex-col">
          {/* Poster — fixed aspect ratio so all cards align regardless of orientation. */}
          <div class="aspect-[3/4] overflow-hidden rounded-lg mb-4 bg-surface border border-border">
            <img
              src={talk.poster}
              alt={`Poster for "${talk.topic}"`}
              class="w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-[1.02]"
            />
          </div>

          <p class="text-[11px] font-mono text-green text-ink-faint mb-1 tracking-wide">
            {formatDate(talk.date)} &nbsp;·&nbsp; {talk.venue}
          </p>

          <h3 class="text-[15px] font-medium text-ink mb-2 leading-snug">
            {talk.topic}
          </h3>

          <p class="text-[13px] text-ink-muted leading-relaxed mb-3 flex-1">
            {talk.description}
          </p>

          {talk.link && (
            <a
              href={talk.link}
              target="_blank"
              rel="noopener noreferrer"
              class="text-[12px] font-mono text-green hover:underline underline-offset-4"
            >
              {talk.linkLabel}
            </a>
          )}
        </li>
      ))
    }
  </ul>
</div>
